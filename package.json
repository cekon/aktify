{
  "name": "scr",
  "version": "1.0.0",
  "description": "Интернет магазин головоломок под торговой маркой \"Мудрец механики\"",
  "main": "index.js",
  "scripts": {
  "build:html": "html-minifier-terser index.html -o ../index.html --collapse-whitespace --remove-comments",
  "build:css": "cleancss -o ../assets/styles.css assets/styles.css",
  "build:js": "uglifyjs assets/app.js -o ../assets/app.js -c -m",
  "build": "npm run build:html && npm run build:css && npm run build:js"
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "html-minifier-terser": "^7.2.0",
    "minify": "^15.3.1",
    "uglify-js": "^3.19.3"
  }
}
